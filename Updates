<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Money Mango — Psychology & Finance</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700;900&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
:root{
  --bg:#050505;
  --surface:rgba(255,255,255,0.05);
  --surface-2:rgba(255,255,255,0.08);
  --border:rgba(255,255,255,0.08);
  --text:#f5f5f5;
  --muted:#9f9f9f;
  --gold:#f5c318;
  --orange:#f08a00;
  --teal:#2db8a0;
  --shadow:0 10px 40px rgba(0,0,0,0.45);
  --blur:blur(18px);
}

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

html{
  scroll-behavior:smooth;
}

body{
  background:var(--bg);
  color:var(--text);
  font-family:'Inter',sans-serif;
  overflow-x:hidden;
}

body::before{
  content:'';
  position:fixed;
  inset:0;
  background:
  radial-gradient(circle at top left, rgba(245,195,24,0.08), transparent 35%),
  radial-gradient(circle at bottom right, rgba(45,184,160,0.08), transparent 30%),
  radial-gradient(circle at center, rgba(255,255,255,0.03), transparent 40%);
  pointer-events:none;
  z-index:-1;
}

nav{
  position:fixed;
  top:0;
  width:100%;
  z-index:1000;
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:22px 60px;
  backdrop-filter:var(--blur);
  background:rgba(5,5,5,0.55);
  border-bottom:1px solid var(--border);
}

.logo{
  display:flex;
  align-items:center;
  gap:14px;
}

.logo-circle{
  width:42px;
  height:42px;
  border-radius:50%;
  background:linear-gradient(135deg,var(--gold),var(--orange));
  box-shadow:0 0 40px rgba(245,195,24,0.35);
}

.logo-text{
  display:flex;
  flex-direction:column;
}

.logo-text small{
  letter-spacing:4px;
  color:var(--gold);
  font-size:10px;
}

.logo-text span{
  font-family:'Playfair Display',serif;
  font-size:24px;
  font-weight:900;
}

.nav-links{
  display:flex;
  gap:32px;
  align-items:center;
}

.nav-links a{
  color:var(--muted);
  text-decoration:none;
  transition:0.3s ease;
}

.nav-links a:hover{
  color:white;
}

.cta{
  padding:12px 22px;
  border-radius:999px;
  background:linear-gradient(135deg,var(--gold),var(--orange));
  color:black !important;
  font-weight:600;
}

.hero{
  min-height:100vh;
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  text-align:center;
  padding:160px 24px 120px;
  position:relative;
}

.hero-glow{
  position:absolute;
  width:700px;
  height:700px;
  border-radius:50%;
  background:radial-gradient(circle, rgba(245,195,24,0.14), transparent 65%);
  top:50%;
  left:50%;
  transform:translate(-50%,-50%);
  filter:blur(40px);
}

.hero h1{
  font-family:'Playfair Display',serif;
  font-size:clamp(3rem,8vw,7rem);
  line-height:0.95;
  max-width:1000px;
  letter-spacing:-4px;
  position:relative;
  z-index:2;
}

.gradient{
  background:linear-gradient(135deg,var(--gold),var(--orange));
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
}

.teal{
  background:linear-gradient(135deg,var(--teal),#79f0dc);
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
}

.hero p{
  max-width:700px;
  margin-top:30px;
  color:var(--muted);
  font-size:1.1rem;
  line-height:1.8;
  position:relative;
  z-index:2;
}

.hero-actions{
  margin-top:42px;
  display:flex;
  gap:18px;
  flex-wrap:wrap;
  justify-content:center;
}

.btn-primary,
.btn-secondary{
  padding:16px 30px;
  border-radius:999px;
  text-decoration:none;
  transition:0.35s ease;
  backdrop-filter:var(--blur);
}

.btn-primary{
  background:linear-gradient(135deg,var(--gold),var(--orange));
  color:black;
  font-weight:700;
  box-shadow:0 10px 30px rgba(245,195,24,0.25);
}

.btn-primary:hover{
  transform:translateY(-4px) scale(1.02);
}

.btn-secondary{
  border:1px solid var(--border);
  color:white;
  background:rgba(255,255,255,0.04);
}

.btn-secondary:hover{
  background:rgba(255,255,255,0.08);
  transform:translateY(-4px);
}

.stats{
  margin-top:90px;
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:30px;
  width:min(900px,100%);
}

.stat{
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:28px;
  padding:40px;
  backdrop-filter:var(--blur);
  box-shadow:var(--shadow);
}

.stat h2{
  font-family:'Playfair Display',serif;
  font-size:3rem;
  color:var(--gold);
}

.stat p{
  margin-top:10px;
  font-size:0.95rem;
}

section{
  padding:120px 8%;
}

.section-head{
  margin-bottom:60px;
}

.section-head small{
  letter-spacing:4px;
  color:var(--orange);
}

.section-head h2{
  margin-top:18px;
  font-size:clamp(2rem,5vw,4rem);
  font-family:'Playfair Display',serif;
}

.section-head p{
  margin-top:20px;
  color:var(--muted);
  max-width:700px;
  line-height:1.8;
}

.cards{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:28px;
}

.card{
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:30px;
  padding:40px;
  backdrop-filter:var(--blur);
  transition:0.4s ease;
  position:relative;
  overflow:hidden;
}

.card::before{
  content:'';
  position:absolute;
  inset:0;
  background:linear-gradient(135deg,rgba(255,255,255,0.08),transparent);
  opacity:0;
  transition:0.4s ease;
}

.card:hover{
  transform:translateY(-12px);
  border-color:rgba(245,195,24,0.25);
}

.card:hover::before{
  opacity:1;
}

.card span{
  font-size:2rem;
}

.card h3{
  margin-top:22px;
  font-size:1.6rem;
  font-family:'Playfair Display',serif;
}

.card p{
  margin-top:14px;
  color:var(--muted);
  line-height:1.8;
}

.featured-video{
  position:relative;
  border-radius:36px;
  overflow:hidden;
  min-height:620px;
  background:black;
  box-shadow:var(--shadow);
  border:1px solid var(--border);
}

.featured-video iframe{
  width:100%;
  height:620px;
  border:none;
}

.video-overlay{
  position:absolute;
  inset:auto 0 0 0;
  padding:50px;
  background:linear-gradient(to top, rgba(0,0,0,0.9), transparent);
}

.video-overlay h3{
  font-size:2rem;
  font-family:'Playfair Display',serif;
}

.video-grid{
  margin-top:40px;
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:24px;
}

.video-card{
  background:var(--surface);
  border-radius:26px;
  overflow:hidden;
  border:1px solid var(--border);
  transition:0.35s ease;
  backdrop-filter:var(--blur);
}

.video-card:hover{
  transform:translateY(-10px) scale(1.01);
}

.video-card img{
  width:100%;
  height:220px;
  object-fit:cover;
}

.video-info{
  padding:24px;
}

.video-info h4{
  font-size:1.2rem;
  line-height:1.4;
}

.video-info p{
  margin-top:12px;
  color:var(--muted);
}

.newsletter{
  border-radius:40px;
  padding:80px 50px;
  background:linear-gradient(135deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02));
  border:1px solid var(--border);
  text-align:center;
  backdrop-filter:var(--blur);
  position:relative;
  overflow:hidden;
}

.newsletter::before{
  content:'';
  position:absolute;
  width:500px;
  height:500px;
  background:radial-gradient(circle, rgba(245,195,24,0.12), transparent 70%);
  top:-250px;
  right:-100px;
}

.newsletter h2{
  font-family:'Playfair Display',serif;
  font-size:4rem;
}

.newsletter p{
  margin-top:20px;
  color:var(--muted);
}

.newsletter-form{
  margin-top:34px;
  display:flex;
  justify-content:center;
  gap:14px;
  flex-wrap:wrap;
}

.newsletter input{
  width:320px;
  padding:18px 24px;
  border-radius:999px;
  border:1px solid var(--border);
  background:rgba(255,255,255,0.05);
  color:white;
  outline:none;
}

.newsletter button{
  border:none;
  padding:18px 28px;
  border-radius:999px;
  font-weight:700;
  background:linear-gradient(135deg,var(--gold),var(--orange));
}

footer{
  padding:50px 8%;
  display:flex;
  justify-content:space-between;
  flex-wrap:wrap;
  gap:20px;
  border-top:1px solid var(--border);
}

footer p{
  color:var(--muted);
}

.reveal{
  opacity:0;
  transform:translateY(60px);
  transition:1s ease;
}

.reveal.active{
  opacity:1;
  transform:translateY(0);
}

@media(max-width:980px){
  .cards,
  .video-grid,
  .stats{
    grid-template-columns:1fr;
  }

  .nav-links{
    display:none;
  }

  nav{
    padding:20px;
  }

  .hero h1{
    letter-spacing:-2px;
  }

  .newsletter h2{
    font-size:2.4rem;
  }

  .featured-video iframe{
    height:420px;
  }
}
</style>
</head>
